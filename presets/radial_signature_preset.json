{
  "tab_edge_params": {
    "preprocess": {
      "use_clahe": true,
      "clahe_clip_limit": 2.71,
      "clahe_tile_grid_size": 17,
      "use_gaussian": true,
      "gaussian_kernel": 1,
      "gaussian_sigma": 2.55
    },
    "threshold": {
      "use_otsu": true,
      "manual_value": 0,
      "invert": false
    },
    "radius_filter": {
      "enabled": true,
      "r_min_factor": 1.13,
      "r_max_factor": 1.37,
      "inner_margin_px": 0.0,
      "outer_margin_px": 0.0
    },
    "component_filter": {
      "min_area": 3000,
      "max_area": 0
    },
    "canny": {
      "threshold1": 70,
      "threshold2": 170,
      "aperture_size": 3,
      "l2_gradient": false
    }
  },
  "radial_params": {
    "source_mode": "tab_edges_clean",
    "use_radius_band": false,
    "inner_radius_scale": 1.0,
    "outer_radius_scale": 1.3,
    "use_source_dilate": false,
    "source_dilate_kernel": 3,
    "source_dilate_iter": 1,
    "num_angles": 360,
    "ray_step_px": 1.0,
    "ray_thickness": 2,
    "min_valid_radius_scale": 1.0,
    "floor_to_radius": true,
    "reject_outliers": false,
    "outlier_window": 11,
    "outlier_max_delta": 16.0,
    "interpolate_missing": true,
    "max_gap_to_interpolate": 18,
    "smooth_signature": true,
    "smooth_window": 7,
    "scale_normalize": true,
    "invert_angle": false
  }
}