{
  "preprocess": {
    "use_clahe": true,
    "clahe_clip_limit": 2.71,
    "clahe_tile_grid_size": 17,
    "use_gaussian": true,
    "gaussian_kernel": 1,
    "gaussian_sigma": 2.55
  },
  "threshold": {
    "use_otsu": true,
    "manual_value": 0,
    "invert": false
  },
  "radius_filter": {
    "enabled": true,
    "r_min_factor": 1.13,
    "r_max_factor": 1.37,
    "inner_margin_px": 0.0,
    "outer_margin_px": 0.0
  },
  "component_filter": {
    "min_area": 3000,
    "max_area": 0
  },
  "canny": {
    "threshold1": 70,
    "threshold2": 170,
    "aperture_size": 3,
    "l2_gradient": false
  }
}