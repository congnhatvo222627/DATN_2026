{
  "preprocess": {
    "use_clahe": false,
    "clahe_clip_limit": 2.0,
    "clahe_tile_grid_size": 8,
    "gaussian_kernel": 5,
    "gaussian_sigma": 1.0
  },
  "threshold": {
    "use_otsu": true,
    "manual_value": 0,
    "invert": true
  },
  "radius_filter": {
    "enabled": true,
    "r_min_factor": 1.0,
    "r_max_factor": 1.3,
    "inner_margin_px": 0.0,
    "outer_margin_px": 0.0
  },
  "component_filter": {
    "min_area": 1500,
    "max_area": 0,
    "angle_bin_deg": 5.0,
    "max_angle_span_deg": 0.0
  },
  "canny": {
    "threshold1": 70,
    "threshold2": 170,
    "aperture_size": 3,
    "l2_gradient": false
  }
}
